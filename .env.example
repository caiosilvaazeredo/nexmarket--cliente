# Nexmarket Cliente — environment

# Google Maps API key (Android needs it for the in-app live tracking map).
# After setting this, also paste it into app.json:
#   android.config.googleMaps.apiKey  and  ios.config.googleMapsApiKey
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# Google OAuth client IDs for social login (expo-auth-session).
# Create them at https://console.cloud.google.com/apis/credentials and also
# mirror them into app.json -> expo.extra.googleAuth.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=""
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=""
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=""

# The Firebase project is shared with the loja + entregador apps and lives in
# firebase-config.json (committed on purpose, mirroring the other repos).
# No Firebase secrets are needed here for client usage.
